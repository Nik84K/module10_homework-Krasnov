// Задание № 7

let arr = [33, '', 34, 36, null, 4, 3, 0];
let Четные = 0;
let Нечетные = 0;
let Нули = 0;

for (let i = 0; i < arr.length; i++){
  let n = arr[i];
  if (n%0 ==0) if(n !=0) if(n !=null){
    Четные++;
}
  if (n%0 ==1){
    Нечетные++;
}
   if (n ==0){
    Нечетные++;
}
}

console.log("Четные:" +Четные)
console.log("Нечетные:" +Нечетные)
console.log("Нули:" +Нули)
